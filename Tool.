#!/bin/bash

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
NC='\033[0m'

WORK_DIR="$HOME/vpn_phuc"
CONFIG_DIR="$WORK_DIR/configs"
LOG_DIR="$WORK_DIR/logs"

mkdir -p "$CONFIG_DIR" "$LOG_DIR"

banner() {
    clear
    echo -e "${CYAN}╔═══════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║     VPN ROTATOR - PHUC v1.0          ║${NC}"
    echo -e "${CYAN}║     Chuyen doi VPN tu dong            ║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════╝${NC}"
    echo ""
}

check_ping() {
    ping -c 2 -W 2 1.1.1.1 > /dev/null 2>&1
    return $?
}

get_ip() {
    IP=$(curl -s --max-time 3 https://api.ipify.org 2>/dev/null)
    if [ -n "$IP" ]; then
        echo -e "${GREEN}🌐 IP hien tai: ${WHITE}$IP${NC}"
    else
        echo -e "${RED}❌ Khong the lay IP${NC}"
    fi
}

menu() {
    banner
    echo -e "${YELLOW}📋 CHON CHUC NANG:${NC}"
    echo ""
    echo -e "${WHITE}1.${NC} ${GREEN}Chay WireGuard (tu dong chon config)${NC}"
    echo -e "${WHITE}2.${NC} ${GREEN}Chay OpenVPN (tu dong chon config)${NC}"
    echo -e "${WHITE}3.${NC} ${GREEN}Ngat ket noi VPN${NC}"
    echo -e "${WHITE}4.${NC} ${GREEN}Kiem tra IP hien tai${NC}"
    echo -e "${WHITE}5.${NC} ${GREEN}Danh sach config co san${NC}"
    echo -e "${WHITE}6.${NC} ${GREEN}Chay vong lap tu dong (xoay moi 180s)${NC}"
    echo -e "${WHITE}7.${NC} ${RED}Thoat${NC}"
    echo ""
    echo -n -e "${CYAN}👉 Nhap lua chon: ${NC}"
    read choice
    case $choice in
        1) run_wireguard ;;
        2) run_openvpn ;;
        3) kill_vpn ;;
        4) get_ip ;;
        5) list_configs ;;
        6) auto_loop ;;
        7) echo -e "${RED}👋 Tam biet!${NC}"; exit 0 ;;
        *) echo -e "${RED}❌ Lua chon khong hop le!${NC}"; sleep 2; menu ;;
    esac
}

run_wireguard() {
    echo -e "${YELLOW}🔄 Dang chay WireGuard...${NC}"
    found=0
    for cfg in "$CONFIG_DIR"/*.conf; do
        if [ -f "$cfg" ]; then
            found=1
            echo -e "${BLUE}📄 Dung config: $(basename "$cfg")${NC}"
            wg-quick down "$cfg" 2>/dev/null
            sleep 1
            wg-quick up "$cfg" 2>/dev/null
            sleep 3
            if check_ping; then
                echo -e "${GREEN}✅ Ket noi thanh cong!${NC}"
                get_ip
                echo ""
                echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
                read
                menu
                return 0
            fi
        fi
    done
    if [ $found -eq 0 ]; then
        echo -e "${RED}❌ Khong tim thay file .conf trong $CONFIG_DIR${NC}"
    else
        echo -e "${RED}❌ Tat ca config deu that bai${NC}"
    fi
    echo ""
    echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
    read
    menu
}

run_openvpn() {
    echo -e "${YELLOW}🔄 Dang chay OpenVPN...${NC}"
    found=0
    for cfg in "$CONFIG_DIR"/*.ovpn; do
        if [ -f "$cfg" ]; then
            found=1
            echo -e "${BLUE}📄 Dung config: $(basename "$cfg")${NC}"
            pkill -f openvpn 2>/dev/null
            sleep 1
            openvpn --config "$cfg" --daemon 2>/dev/null
            sleep 5
            if check_ping; then
                echo -e "${GREEN}✅ Ket noi thanh cong!${NC}"
                get_ip
                echo ""
                echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
                read
                menu
                return 0
            fi
        fi
    done
    if [ $found -eq 0 ]; then
        echo -e "${RED}❌ Khong tim thay file .ovpn trong $CONFIG_DIR${NC}"
    else
        echo -e "${RED}❌ Tat ca config deu that bai${NC}"
    fi
    echo ""
    echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
    read
    menu
}

kill_vpn() {
    echo -e "${YELLOW}🔴 Dang ngat VPN...${NC}"
    pkill -f openvpn 2>/dev/null
    for cfg in "$CONFIG_DIR"/*.conf; do
        if [ -f "$cfg" ]; then
            wg-quick down "$cfg" 2>/dev/null
        fi
    done
    echo -e "${GREEN}✅ Da ngat ket noi VPN${NC}"
    sleep 1
    get_ip
    echo ""
    echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
    read
    menu
}

list_configs() {
    echo -e "${BLUE}📂 Danh sach config:${NC}"
    echo ""
    wg_count=0
    ovpn_count=0
    for cfg in "$CONFIG_DIR"/*.conf; do
        if [ -f "$cfg" ]; then
            echo -e "${GREEN}🔹 $(basename "$cfg")${NC} ${WHITE}(WireGuard)${NC}"
            wg_count=$((wg_count+1))
        fi
    done
    for cfg in "$CONFIG_DIR"/*.ovpn; do
        if [ -f "$cfg" ]; then
            echo -e "${CYAN}🔸 $(basename "$cfg")${NC} ${WHITE}(OpenVPN)${NC}"
            ovpn_count=$((ovpn_count+1))
        fi
    done
    if [ $wg_count -eq 0 ] && [ $ovpn_count -eq 0 ]; then
        echo -e "${RED}❌ Khong co config nao!${NC}"
        echo -e "${YELLOW}📥 Hay dat file .conf hoac .ovpn vao: $CONFIG_DIR${NC}"
    else
        echo ""
        echo -e "${WHITE}Tong: ${wg_count} WireGuard, ${ovpn_count} OpenVPN${NC}"
    fi
    echo ""
    echo -e "${YELLOW}Nhan Enter de tiep tuc...${NC}"
    read
    menu
}

auto_loop() {
    echo -e "${YELLOW}🔄 Khoi dong vong lap tu dong (xoay moi 180s)${NC}"
    echo -e "${RED}⚠️ Nhan Ctrl+C de dung${NC}"
    echo ""
    sleep 2
    while true; do
        echo -e "${BLUE}--- ${YELLOW}$(date '+%H:%M:%S')${BLUE} ---${NC}"
        for cfg in "$CONFIG_DIR"/*.conf; do
            if [ -f "$cfg" ]; then
                wg-quick down "$cfg" 2>/dev/null
                sleep 1
                wg-quick up "$cfg" 2>/dev/null
                sleep 3
                if check_ping; then
                    echo -e "${GREEN}✅ $(basename "$cfg") thanh cong${NC}"
                    get_ip
                    break
                fi
            fi
        done
        echo -e "${YELLOW}⏳ Cho 180 giay...${NC}"
        sleep 180
    done
}

menu
